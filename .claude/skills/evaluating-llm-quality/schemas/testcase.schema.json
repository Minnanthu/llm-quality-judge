{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/testcase.schema.json",
  "title": "Testcase",
  "type": "object",
  "required": [
    "testcase_id",
    "task_type",
    "input"
  ],
  "additionalProperties": false,
  "properties": {
    "testcase_id": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "enum": [
        "preprocessing",
        "report_generation",
        "report_qa"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "difficulty": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "input_length_bucket": {
          "type": "string",
          "enum": [
            "S",
            "M",
            "L"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "input": {
      "type": "object",
      "oneOf": [
        {
          "required": ["messages"],
          "additionalProperties": false,
          "properties": {
            "messages": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["role", "content"],
                "additionalProperties": false,
                "properties": {
                  "role": { "type": "string", "enum": ["system", "user", "assistant"] },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        {
          "not": { "required": ["messages"] },
          "additionalProperties": true
        }
      ]
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_format": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "free_text",
                "markdown",
                "json"
              ]
            },
            "json_schema_ref": {
              "type": "string"
            },
            "template_ref": {
              "type": "string"
            }
          }
        },
        "citation_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean",
              "default": false
            },
            "allowed_sources": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
