{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/judgement-record.schema.json",
  "title": "JudgementRecord",
  "type": "object",
  "required": [
    "run_id",
    "testcase_id",
    "judge",
    "mode",
    "targets",
    "scores"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "testcase_id": {
      "type": "string"
    },
    "judge": {
      "type": "object",
      "required": [
        "judge_id",
        "vendor",
        "model_id",
        "rubric_version"
      ],
      "additionalProperties": false,
      "properties": {
        "judge_id": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "rubric_version": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "pairwise",
        "absolute"
      ]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "inference_ref"
        ],
        "additionalProperties": false,
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "inference_ref": {
            "type": "object",
            "required": [
              "path",
              "line_index"
            ],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string"
              },
              "line_index": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "blinding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "presented_order": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Judgeに提示した順（candidate_idの配列）"
        },
        "random_seed": {
          "type": "integer"
        }
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "per_metric"
      ],
      "properties": {
        "per_metric": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "enum": [
              1,
              3,
              5
            ]
          }
        },
        "overall_winner": {
          "type": "string",
          "description": "pairwise の場合: candidate_id or 'tie'"
        },
        "overall_score": {
          "type": "number",
          "description": "absolute の場合などに使用（任意）"
        }
      }
    },
    "rationale": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source_ref": {
            "type": "string"
          },
          "span": {
            "type": "string"
          }
        }
      }
    }
  }
}
