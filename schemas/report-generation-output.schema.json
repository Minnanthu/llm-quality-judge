{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/report-generation-output.schema.json",
  "title": "ReportGenerationOutput",
  "description": "深掘り分析タスクのJSON出力スキーマ",
  "type": "object",
  "required": [
    "summary",
    "facts",
    "hypotheses",
    "conclusion",
    "caveats"
  ],
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conclusion": {
      "type": "string",
      "minLength": 1
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
